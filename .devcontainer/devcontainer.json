{
    "name": "VetSalud BD2",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspace",
    "postCreateCommand": "pip install --no-cache-dir -r requirements.txt",
    "customizations": {
        "vscode": {
            "extensions": [
            "ms-python.python",
            "mongodb.mongodb-vscode",
            "cweijan.vscode-redis-client"
            ]
        }
    }
}

